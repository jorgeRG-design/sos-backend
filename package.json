{
  "name": "sos-backend",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:init": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/database/db-init.ps1",
    "db:migrate": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/database/db-migrate.ps1",
    "clasificador:import": "node scripts/importar_clasificador.js",
    "firestore:seed": "node scripts/firestore/seed.js",
    "backup:postgres": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/backup/backup-postgres.ps1",
    "backup:uploads": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/backup/backup-uploads.ps1",
    "backup:firestore": "node scripts/backup/backup-firestore.js",
    "backup:all": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/backup/run-backup-all.ps1",
    "restore:postgres": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/backup/restore-postgres.ps1",
    "restore:uploads": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/backup/restore-uploads.ps1",
    "restore:firestore": "node scripts/backup/restore-firestore.js",
    "backup:schedule:preview": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/backup/register_backup_tasks.ps1",
    "backup:schedule:apply": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/backup/register_backup_tasks.ps1 -Apply",
    "retention:verification:dry": "node scripts/retention/verification_codes_prune.js --mode=dry-run",
    "retention:verification:run": "node scripts/retention/verification_codes_prune.js --mode=execute",
    "retention:attachments:report": "node scripts/retention/attachments_reconcile_report.js --mode=dry-run",
    "retention:attachments:quarantine:dry": "node scripts/retention/attachments_quarantine_orphans.js --mode=dry-run",
    "retention:attachments:quarantine:run": "node scripts/retention/attachments_quarantine_orphans.js --mode=execute",
    "retention:attachments:restore": "node scripts/retention/attachments_restore_from_quarantine.js",
    "retention:audit:dry": "node scripts/retention/audit_events_archive_rollover.js --mode=dry-run",
    "retention:audit:run": "node scripts/retention/audit_events_archive_rollover.js --mode=execute",
    "retention:gps:dry": "node scripts/retention/gps_retention_prune.js --mode=dry-run",
    "retention:gps:run": "node scripts/retention/gps_retention_prune.js --mode=execute",
    "retention:camera-log:dry": "node scripts/retention/camera_log_prune.js --mode=dry-run",
    "retention:camera-log:run": "node scripts/retention/camera_log_prune.js --mode=execute",
    "retention:camera-daily:dry": "node scripts/retention/camera_daily_reports_retention.js --mode=dry-run",
    "retention:camera-daily:run": "node scripts/retention/camera_daily_reports_retention.js --mode=execute",
    "retention:schedule:preview": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/retention/register_windows_tasks.ps1",
    "retention:schedule:apply": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/retention/register_windows_tasks.ps1 -Apply"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.3",
    "pg": "^8.20.0"
  }
}
