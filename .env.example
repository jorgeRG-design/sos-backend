# Copiar a .env y ajustar. No commitear .env ni firebase-key.json.

PORT=3000
API_KEY=cambiar_por_clave_compartida_con_la_app

# PostgreSQL
PG_USER=postgres
PG_HOST=localhost
PG_DATABASE=sos_santa_anita
PG_PASSWORD=
PG_PORT=5432
# PG_SSL=false
# PG_SSL_REJECT_UNAUTHORIZED=true

# Archivos adjuntos a incidencias (carpetas locales; sin MinIO)
# UPLOAD_DIR=ruta/absoluta/opcional  (por defecto: sos-backend/uploads)
# MAX_UPLOAD_IMAGE_BYTES=8388608
# MAX_UPLOAD_PDF_BYTES=15728640

# Backup / recovery (recomendado: almacenamiento externo al servidor operativo)
# Los scripts aceptan tanto POSTGRES_* como los PG_* ya usados por la app.
# BACKUP_ROOT_DIR=D:\SOSBackups
# LOG_DIR=D:\SOSBackups\logs
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=sos_santa_anita
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# FIREBASE_CREDENTIALS_PATH=C:\rutas\seguras\firebase-key.json
FIRESTORE_COLLECTIONS=ciudadanos,usuarios_central,alertas,recorridos_gps,bitacora_camaras,reportes_diarios_camaras
# BACKUP_PG_DUMP_PATH=C:\Program Files\PostgreSQL\17\bin\pg_dump.exe
# BACKUP_PG_RESTORE_PATH=C:\Program Files\PostgreSQL\17\bin\pg_restore.exe
# BACKUP_PSQL_PATH=C:\Program Files\PostgreSQL\17\bin\psql.exe

# Codigos de verificacion (email)
VERIFICATION_CODE_EXPIRY_MINUTES=15
VERIFICATION_SEND_COOLDOWN_SECONDS=60
VERIFICATION_VERIFY_MAX_ATTEMPTS=5
VERIFICATION_VERIFY_LOCK_MINUTES=15
VERIFICATION_VERIFY_IP_WINDOW_MS=600000
VERIFICATION_VERIFY_IP_MAX_ATTEMPTS=30
# SMTP_HOST=smtp.ejemplo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="SOS Santa Anita <no-reply@ejemplo.com>"

# Solo desarrollo / pruebas
# En produccion se recomienda REQUIRE_HTTPS=true y usar solo credenciales por entorno.
# REQUIRE_HTTPS=true
# FIREBASE_ALLOW_LOCAL_FILE_FALLBACK=false
VERIFICATION_DEBUG_FALLBACK=true
VERIFICATION_DEBUG_EXPOSE_CODE=false

# Auditoria client-driven (login_failure pre-auth)
AUDIT_LOGIN_FAILURE_WINDOW_MS=600000
AUDIT_LOGIN_FAILURE_IP_MAX_EVENTS=20
AUDIT_LOGIN_FAILURE_IDENTIFIER_MAX_EVENTS=5

# Retencion / purga backend (jobs CLI)
RETENTION_ENABLE_PRUNE=false
RETENTION_MAX_DELETE_PER_RUN=500
# RETENTION_ATTACHMENTS_QUARANTINE_DIR=ruta/absoluta/opcional (por defecto: <UPLOAD_DIR>/_retention_quarantine)
